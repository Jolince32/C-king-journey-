#include <stdio.h>
int main() {
    int marks[] = {80, 90, 70};
    int sum = 0;
    int n = 3; // Total elements

    for(int i = 0; i < n; i++) {
        sum = sum + marks[i];
    }

    float avg = (float)sum / n; // float podanum da, illana 80 varum
    printf("Average = %.2f", avg); // Output: 80.00
    return 0;
}